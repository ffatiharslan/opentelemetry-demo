{
  "uid": "nginx-metrics-dashboard",
  "title": "NGINX Metrics Dashboard",
  "description": "Comprehensive NGINX monitoring dashboard based on OpenTelemetry metrics collected via Prometheus. Covers connection lifecycle, request throughput, connection states, and drop analysis. Refresh: 30s. Tags: nginx, opentelemetry.",
  "tags": ["nginx", "opentelemetry"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {"type": "row", "title": "Overview", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "collapsed": false},
    {"type": "stat", "title": "Total Requests", "gridPos": {"h": 4, "w": 6, "x": 0, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}, "targets": [{"expr": "nginx_requests_total", "legendFormat": "Requests", "refId": "A"}]},
    {"type": "stat", "title": "Request Rate", "gridPos": {"h": 4, "w": 6, "x": 6, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 500}, {"color": "red", "value": 1000}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"}, "targets": [{"expr": "rate(nginx_requests_total[1m])", "legendFormat": "req/s", "refId": "A"}]},
    {"type": "stat", "title": "Active Connections", "gridPos": {"h": 4, "w": 6, "x": 12, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 500}, {"color": "red", "value": 1000}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"}, "targets": [{"expr": "nginx_connections_current{state=\"active\"}", "legendFormat": "Active", "refId": "A"}]},
    {"type": "stat", "title": "Dropped Connections", "gridPos": {"h": 4, "w": 6, "x": 18, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"}, "targets": [{"expr": "nginx_connections_accepted_total - nginx_connections_handled_total", "legendFormat": "Dropped", "refId": "A"}]},
    {"type": "row", "title": "Request Throughput", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "collapsed": false},
    {"type": "timeseries", "title": "Request Rate (req/s)", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 15}, "color": {"fixedColor": "blue", "mode": "fixed"}}}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(nginx_requests_total[1m])", "legendFormat": "Requests/sec (1m)", "refId": "A"}, {"expr": "rate(nginx_requests_total[5m])", "legendFormat": "Requests/sec (5m)", "refId": "B"}]},
    {"type": "timeseries", "title": "Cumulative Total Requests", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "nginx_requests_total", "legendFormat": "Total Requests", "refId": "A"}]},
    {"type": "row", "title": "Connections — Lifecycle", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}, "collapsed": false},
    {"type": "timeseries", "title": "Accepted vs Handled Connections (Rate)", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "cps", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Handled"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Accepted"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(nginx_connections_accepted_total[1m])", "legendFormat": "Accepted", "refId": "A"}, {"expr": "rate(nginx_connections_handled_total[1m])", "legendFormat": "Handled", "refId": "B"}]},
    {"type": "timeseries", "title": "Dropped Connections Rate", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "cps", "custom": {"lineWidth": 2, "fillOpacity": 15}}, "overrides": [{"matcher": {"id": "byName", "options": "Dropped"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(nginx_connections_accepted_total[1m]) - rate(nginx_connections_handled_total[1m])", "legendFormat": "Dropped", "refId": "A"}]},
    {"type": "timeseries", "title": "Cumulative Accepted vs Handled Connections", "gridPos": {"h": 8, "w": 24, "x": 0, "y": 23}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Handled"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Accepted"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Dropped (gap)"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "nginx_connections_accepted_total", "legendFormat": "Accepted", "refId": "A"}, {"expr": "nginx_connections_handled_total", "legendFormat": "Handled", "refId": "B"}, {"expr": "nginx_connections_accepted_total - nginx_connections_handled_total", "legendFormat": "Dropped (gap)", "refId": "C"}]},
    {"type": "row", "title": "Connections — Current State", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31}, "collapsed": false},
    {"type": "timeseries", "title": "Current Connections by State", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "active"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "reading"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "writing"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "waiting"}, "properties": [{"id": "color", "value": {"fixedColor": "purple", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "nginx_connections_current", "legendFormat": "{{state}}", "refId": "A"}]},
    {"type": "piechart", "title": "Connection State Distribution", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short"}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "pieType": "donut", "legend": {"displayMode": "list", "placement": "right"}}, "targets": [{"expr": "nginx_connections_current", "legendFormat": "{{state}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Waiting (Keep-Alive) Connections", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 40}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}, "color": {"fixedColor": "purple", "mode": "fixed"}}}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "nginx_connections_current{state=\"waiting\"}", "legendFormat": "Waiting", "refId": "A"}]},
    {"type": "timeseries", "title": "Reading & Writing Connections", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 40}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Reading"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Writing"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "nginx_connections_current{state=\"reading\"}", "legendFormat": "Reading", "refId": "A"}, {"expr": "nginx_connections_current{state=\"writing\"}", "legendFormat": "Writing", "refId": "B"}]},
    {"type": "row", "title": "Efficiency Analysis", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 48}, "collapsed": false},
    {"type": "timeseries", "title": "Connection Handle Rate %", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 49}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"lineWidth": 2, "fillOpacity": 15}, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 95}, {"color": "green", "value": 99}]}}}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "100 * rate(nginx_connections_handled_total[1m]) / rate(nginx_connections_accepted_total[1m])", "legendFormat": "Handle Rate %", "refId": "A"}]},
    {"type": "timeseries", "title": "Requests per Connection", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 49}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}, "decimals": 2}}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(nginx_requests_total[1m]) / rate(nginx_connections_handled_total[1m])", "legendFormat": "Requests per Connection", "refId": "A"}]}
  ]
}