{
  "uid": "redis-metrics-dashboard",
  "title": "Redis Metrics Dashboard",
  "description": "Comprehensive Redis monitoring dashboard based on 29 OpenTelemetry metrics collected via Prometheus. Covers memory usage, command performance, keyspace hit/miss rates, network I/O, CPU, persistence, and replication. Refresh: 30s. Tags: redis, opentelemetry.",
  "tags": ["redis", "opentelemetry"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "title": "Overview", "type": "row"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}, "unit": "s"}}, "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1}, "options": {"colorMode": "value", "graphMode": "none", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"}, "targets": [{"expr": "redis_uptime_seconds_total", "legendFormat": "Uptime", "refId": "A"}], "title": "Uptime", "type": "stat"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 100}]}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1}, "options": {"colorMode": "background", "graphMode": "area", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"}, "targets": [{"expr": "redis_clients_connected", "legendFormat": "Clients", "refId": "A"}], "title": "Connected Clients", "type": "stat"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 20}]}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1}, "options": {"colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"}, "targets": [{"expr": "redis_clients_blocked", "legendFormat": "Blocked", "refId": "A"}], "title": "Blocked Clients", "type": "stat"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}, "unit": "short"}}, "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1}, "options": {"colorMode": "value", "graphMode": "area", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"}, "targets": [{"expr": "sum(redis_db_keys)", "legendFormat": "Keys", "refId": "A"}], "title": "Total DB Keys", "type": "stat"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}]}, "unit": "ops"}}, "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1}, "options": {"colorMode": "value", "graphMode": "area", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"}, "targets": [{"expr": "redis_commands_per_second", "legendFormat": "Cmd/s", "refId": "A"}], "title": "Commands/sec", "type": "stat"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "decimals": 2, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1.5}, {"color": "red", "value": 2}]}, "unit": "none"}}, "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1}, "options": {"colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto"}, "targets": [{"expr": "redis_memory_fragmentation_ratio", "legendFormat": "Frag Ratio", "refId": "A"}], "title": "Memory Fragmentation Ratio", "type": "stat"},
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "title": "Memory", "type": "row"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "bytes"}, "overrides": [{"matcher": {"id": "byName", "options": "Peak"}, "properties": [{"id": "custom.lineStyle", "value": {"dash": [5, 5], "fill": "dash"}}]}, {"matcher": {"id": "byName", "options": "RSS"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}]}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "redis_memory_used_bytes", "legendFormat": "Used", "refId": "A"}, {"expr": "redis_memory_peak_bytes", "legendFormat": "Peak", "refId": "B"}, {"expr": "redis_memory_rss_bytes", "legendFormat": "RSS", "refId": "C"}, {"expr": "redis_memory_lua_bytes", "legendFormat": "Lua", "refId": "D"}], "title": "Memory Usage", "type": "timeseries"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1.5}, {"color": "red", "value": 2}]}, "unit": "none"}}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}, "targets": [{"expr": "redis_memory_fragmentation_ratio", "legendFormat": "Fragmentation Ratio", "refId": "A"}], "title": "Memory Fragmentation Ratio", "type": "timeseries"},
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}, "title": "Performance & Commands", "type": "row"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "ops"}}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "redis_commands_per_second", "legendFormat": "Commands/sec", "refId": "A"}, {"expr": "rate(redis_commands_processed_total[1m])", "legendFormat": "Processed rate (1m)", "refId": "B"}], "title": "Commands Processed", "type": "timeseries"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "ops"}, "overrides": [{"matcher": {"id": "byName", "options": "Misses"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Hits"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}]}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "rate(redis_keyspace_hits_total[1m])", "legendFormat": "Hits", "refId": "A"}, {"expr": "rate(redis_keyspace_misses_total[1m])", "legendFormat": "Misses", "refId": "B"}], "title": "Keyspace Hits vs Misses", "type": "timeseries"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 15, "lineWidth": 2}, "max": 100, "min": 0, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 80}, {"color": "green", "value": 95}]}, "unit": "percent"}}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 23}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}, "targets": [{"expr": "100 * rate(redis_keyspace_hits_total[1m]) / (rate(redis_keyspace_hits_total[1m]) + rate(redis_keyspace_misses_total[1m]))", "legendFormat": "Hit Rate %", "refId": "A"}], "title": "Hit Rate %", "type": "timeseries"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "short"}, "overrides": [{"matcher": {"id": "byName", "options": "Evicted"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Expired"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}]}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 23}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "rate(redis_keys_evicted_total[1m])", "legendFormat": "Evicted", "refId": "A"}, {"expr": "rate(redis_keys_expired_total[1m])", "legendFormat": "Expired", "refId": "B"}], "title": "Keys Evicted & Expired", "type": "timeseries"},
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31}, "title": "Network & Connections", "type": "row"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "Bps"}, "overrides": [{"matcher": {"id": "byName", "options": "Output"}, "properties": [{"id": "custom.transform", "value": "negative-Y"}]}]}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "rate(redis_net_input_bytes_total[1m])", "legendFormat": "Input", "refId": "A"}, {"expr": "rate(redis_net_output_bytes_total[1m])", "legendFormat": "Output", "refId": "B"}], "title": "Network I/O", "type": "timeseries"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "short"}, "overrides": [{"matcher": {"id": "byName", "options": "Rejected"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "rate(redis_connections_received_total[1m])", "legendFormat": "Received", "refId": "A"}, {"expr": "rate(redis_connections_rejected_total[1m])", "legendFormat": "Rejected", "refId": "B"}], "title": "Connections", "type": "timeseries"},
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 40}, "title": "CPU & Persistence", "type": "row"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "percentunit"}}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 41}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "rate(redis_cpu_time_seconds_total{mode=\"sys\"}[1m])", "legendFormat": "System CPU", "refId": "A"}, {"expr": "rate(redis_cpu_time_seconds_total{mode=\"user\"}[1m])", "legendFormat": "User CPU", "refId": "B"}], "title": "CPU Usage", "type": "timeseries"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "short"}}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 41}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}, "targets": [{"expr": "redis_rdb_changes_since_last_save", "legendFormat": "Unsaved Changes", "refId": "A"}], "title": "RDB Changes Since Last Save", "type": "timeseries"},
    {"collapsed": false, "gridPos": {"h": 1, "w": 24, "x": 0, "y": 49}, "title": "Keyspace & Replication", "type": "row"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "short"}}, "gridPos": {"h": 8, "w": 12, "x": 0, "y": 50}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "redis_db_keys", "legendFormat": "Total Keys ({{db}})", "refId": "A"}, {"expr": "redis_db_expires", "legendFormat": "Expiring Keys ({{db}})", "refId": "B"}], "title": "DB Keys & Expiring Keys", "type": "timeseries"},
    {"datasource": {"type": "prometheus", "uid": "webstore-metrics"}, "fieldConfig": {"defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "unit": "short"}}, "gridPos": {"h": 8, "w": 12, "x": 12, "y": 50}, "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}, "targets": [{"expr": "redis_slaves_connected", "legendFormat": "Connected Slaves", "refId": "A"}, {"expr": "redis_replication_offset_bytes", "legendFormat": "Replication Offset (bytes)", "refId": "B"}, {"expr": "redis_replication_backlog_first_byte_offset_bytes", "legendFormat": "Backlog First Byte Offset", "refId": "C"}], "title": "Replication", "type": "timeseries"}
  ]
}
