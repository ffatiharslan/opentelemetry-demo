{
  "uid": "kafka-metrics-dashboard",
  "title": "Kafka Metrics Dashboard",
  "description": "Comprehensive Kafka monitoring dashboard based on 97 OpenTelemetry metrics. Covers broker health, consumer lag, fetch/commit performance, rebalancing, network I/O, and partition status. Refresh: 30s. Tags: kafka, opentelemetry.",
  "tags": ["kafka", "opentelemetry"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {"type": "row", "title": "Broker Health", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "collapsed": false},
    {"type": "stat", "title": "Active Controllers", "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "auto"}, "targets": [{"expr": "kafka_controller_active_count", "legendFormat": "Controllers", "refId": "A"}]},
    {"type": "stat", "title": "Total Partitions", "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "auto"}, "targets": [{"expr": "sum(kafka_partition_count)", "legendFormat": "Partitions", "refId": "A"}]},
    {"type": "stat", "title": "Offline Partitions", "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "auto"}, "targets": [{"expr": "sum(kafka_partition_offline)", "legendFormat": "Offline", "refId": "A"}]},
    {"type": "stat", "title": "Under-Replicated Partitions", "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 10}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "auto"}, "targets": [{"expr": "sum(kafka_partition_underReplicated)", "legendFormat": "Under-Replicated", "refId": "A"}]},
    {"type": "stat", "title": "Max Consumer Lag", "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1000}, {"color": "red", "value": 10000}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"}, "targets": [{"expr": "max(kafka_lag_max)", "legendFormat": "Max Lag", "refId": "A"}]},
    {"type": "stat", "title": "Total Messages", "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "area", "textMode": "auto"}, "targets": [{"expr": "sum(kafka_message_count_total)", "legendFormat": "Messages", "refId": "A"}]},
    {"type": "row", "title": "Broker — Partitions & Elections", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "collapsed": false},
    {"type": "timeseries", "title": "Partition Status", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Offline"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Under-Replicated"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "sum(kafka_partition_count)", "legendFormat": "Total", "refId": "A"}, {"expr": "sum(kafka_partition_offline)", "legendFormat": "Offline", "refId": "B"}, {"expr": "sum(kafka_partition_underReplicated)", "legendFormat": "Under-Replicated", "refId": "C"}]},
    {"type": "timeseries", "title": "ISR Operations & Unclean Elections", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Unclean Elections"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(kafka_isr_operation_count[1m])", "legendFormat": "ISR {{operation}}", "refId": "A"}, {"expr": "rate(kafka_leaderElection_unclean_count_total[1m])", "legendFormat": "Unclean Elections", "refId": "B"}]},
    {"type": "timeseries", "title": "Purgatory Size", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_purgatory_size", "legendFormat": "{{type}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Network I/O Bytes", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(kafka_network_io_bytes_total[1m])", "legendFormat": "{{direction}}", "refId": "A"}]},
    {"type": "row", "title": "Broker — Messages, Requests & Log Flush", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 22}, "collapsed": false},
    {"type": "timeseries", "title": "Message Rate", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 23}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(kafka_message_count_total[1m])", "legendFormat": "Messages/sec", "refId": "A"}]},
    {"type": "timeseries", "title": "Request Rate by Type", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 23}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(kafka_request_count_total[1m])", "legendFormat": "{{type}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Log Flush Duration (p50 / p99)", "gridPos": {"h": 8, "w": 8, "x": 16, "y": 23}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_logs_flush_time_50p_milliseconds", "legendFormat": "p50", "refId": "A"}, {"expr": "kafka_logs_flush_time_99p_milliseconds", "legendFormat": "p99", "refId": "B"}, {"expr": "rate(kafka_logs_flush_Count_milliseconds_total[1m])", "legendFormat": "Flush Rate", "refId": "C"}]},
    {"type": "row", "title": "Consumer — Lag & Lead", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31}, "collapsed": false},
    {"type": "timeseries", "title": "Consumer Records Lag", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Max Lag"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_records_lag", "legendFormat": "Lag ({{topic}}/{{partition}})", "refId": "A"}, {"expr": "kafka_consumer_records_lag_max", "legendFormat": "Max Lag", "refId": "B"}, {"expr": "kafka_consumer_records_lag_avg", "legendFormat": "Avg Lag", "refId": "C"}]},
    {"type": "timeseries", "title": "Consumer Records Lead", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_records_lead", "legendFormat": "Lead ({{topic}}/{{partition}})", "refId": "A"}, {"expr": "kafka_consumer_records_lead_min", "legendFormat": "Min Lead", "refId": "B"}, {"expr": "kafka_consumer_records_lead_avg", "legendFormat": "Avg Lead", "refId": "C"}]},
    {"type": "timeseries", "title": "Max Lag by Client", "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_lag_max", "legendFormat": "{{client_id}}", "refId": "A"}]},
    {"type": "row", "title": "Consumer — Records & Bytes Consumed", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 48}, "collapsed": false},
    {"type": "timeseries", "title": "Records Consumed Rate", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 49}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_records_consumed_rate", "legendFormat": "{{client_id}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Bytes Consumed Rate", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 49}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_bytes_consumed_rate", "legendFormat": "{{client_id}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Fetch Rate & Records per Request", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 57}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_fetch_rate", "legendFormat": "Fetch Rate ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_records_per_request_avg", "legendFormat": "Records/Request avg ({{client_id}})", "refId": "B"}]},
    {"type": "timeseries", "title": "Fetch Latency (Avg / Max)", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 57}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_fetch_latency_avg", "legendFormat": "Avg ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_fetch_latency_max", "legendFormat": "Max ({{client_id}})", "refId": "B"}]},
    {"type": "row", "title": "Consumer — Commits", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 65}, "collapsed": false},
    {"type": "timeseries", "title": "Commit Rate", "gridPos": {"h": 8, "w": 8, "x": 0, "y": 66}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_commit_rate", "legendFormat": "{{client_id}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Commit Latency (Avg / Max)", "gridPos": {"h": 8, "w": 8, "x": 8, "y": 66}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_commit_latency_avg", "legendFormat": "Avg ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_commit_latency_max", "legendFormat": "Max ({{client_id}})", "refId": "B"}]},
    {"type": "timeseries", "title": "Assigned Partitions", "gridPos": {"h": 8, "w": 8, "x": 16, "y": 66}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_assigned_partitions", "legendFormat": "{{client_id}}", "refId": "A"}]},
    {"type": "row", "title": "Consumer — Rebalancing", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 74}, "collapsed": false},
    {"type": "timeseries", "title": "Rebalance Rate & Failed Rebalances", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 75}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Failed"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_rebalance_rate_per_hour", "legendFormat": "Rebalance Rate/hr ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_failed_rebalance_rate_per_hour", "legendFormat": "Failed/hr ({{client_id}})", "refId": "B"}]},
    {"type": "timeseries", "title": "Rebalance Latency (Avg / Max)", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 75}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_rebalance_latency_avg", "legendFormat": "Avg ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_rebalance_latency_max", "legendFormat": "Max ({{client_id}})", "refId": "B"}]},
    {"type": "timeseries", "title": "Join & Sync Rate", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 83}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_join_rate", "legendFormat": "Join Rate ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_sync_rate", "legendFormat": "Sync Rate ({{client_id}})", "refId": "B"}]},
    {"type": "timeseries", "title": "Last Rebalance & Last Heartbeat (seconds ago)", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 83}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_last_rebalance_seconds_ago", "legendFormat": "Last Rebalance ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_last_heartbeat_seconds_ago", "legendFormat": "Last Heartbeat ({{client_id}})", "refId": "B"}]},
    {"type": "row", "title": "Consumer — Network & Connections", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 91}, "collapsed": false},
    {"type": "timeseries", "title": "Network I/O Rate", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 92}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "Bps", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_incoming_byte_rate", "legendFormat": "In ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_outgoing_byte_rate", "legendFormat": "Out ({{client_id}})", "refId": "B"}]},
    {"type": "timeseries", "title": "Connection Count & Creation Rate", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 92}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_connection_count", "legendFormat": "Connections ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_connection_creation_rate", "legendFormat": "Creation Rate ({{client_id}})", "refId": "B"}, {"expr": "kafka_consumer_connection_close_rate", "legendFormat": "Close Rate ({{client_id}})", "refId": "C"}]},
    {"type": "timeseries", "title": "Request Latency (Avg / Max)", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 100}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_request_latency_avg", "legendFormat": "Avg ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_request_latency_max", "legendFormat": "Max ({{client_id}})", "refId": "B"}]},
    {"type": "timeseries", "title": "IO Ratio & IO Wait Ratio", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 100}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percentunit", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_io_ratio", "legendFormat": "IO Ratio ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_io_wait_ratio", "legendFormat": "IO Wait Ratio ({{client_id}})", "refId": "B"}]},
    {"type": "row", "title": "Consumer — Authentication & Heartbeat", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 108}, "collapsed": false},
    {"type": "timeseries", "title": "Authentication Events", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 109}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Failed Auth"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_successful_authentication_rate", "legendFormat": "Success ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_failed_authentication_rate", "legendFormat": "Failed Auth ({{client_id}})", "refId": "B"}, {"expr": "kafka_consumer_failed_reauthentication_rate", "legendFormat": "Failed ReAuth ({{client_id}})", "refId": "C"}]},
    {"type": "timeseries", "title": "Heartbeat Rate & Poll Idle Ratio", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 109}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "kafka_consumer_heartbeat_rate", "legendFormat": "Heartbeat Rate ({{client_id}})", "refId": "A"}, {"expr": "kafka_consumer_poll_idle_ratio_avg", "legendFormat": "Poll Idle Ratio ({{client_id}})", "refId": "B"}]}
  ]
}