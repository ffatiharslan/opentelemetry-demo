{
  "uid": "postgresql-metrics-dashboard",
  "title": "PostgreSQL Metrics Dashboard",
  "description": "Comprehensive PostgreSQL monitoring dashboard based on 27 OpenTelemetry metrics collected via Prometheus. Covers connections, database size, query performance, tuple operations, cache efficiency, bgwriter, replication, and table/index statistics. Refresh: 30s. Tags: postgresql, opentelemetry.",
  "tags": ["postgresql", "opentelemetry"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {"type": "row", "title": "Overview", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}, "collapsed": false},
    {"type": "stat", "title": "Active Backends", "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 50}, {"color": "red", "value": 80}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"}, "targets": [{"expr": "postgresql_backends", "legendFormat": "Backends", "refId": "A"}]},
    {"type": "stat", "title": "Max Connections", "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "auto"}, "targets": [{"expr": "postgresql_connection_max", "legendFormat": "Max", "refId": "A"}]},
    {"type": "stat", "title": "Connection Usage %", "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "textMode": "auto"}, "targets": [{"expr": "100 * postgresql_backends / postgresql_connection_max", "legendFormat": "Usage %", "refId": "A"}]},
    {"type": "stat", "title": "Total Databases", "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "auto"}, "targets": [{"expr": "postgresql_database_count", "legendFormat": "Databases", "refId": "A"}]},
    {"type": "stat", "title": "Total Tables", "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "blue", "value": null}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value", "graphMode": "none", "textMode": "auto"}, "targets": [{"expr": "sum(postgresql_table_count)", "legendFormat": "Tables", "refId": "A"}]},
    {"type": "stat", "title": "Cache Hit Rate %", "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percent", "decimals": 1, "min": 0, "max": 100, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 90}, {"color": "green", "value": 98}]}}}, "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "none", "textMode": "auto"}, "targets": [{"expr": "100 * rate(postgresql_blks_hit_total[5m]) / (rate(postgresql_blks_hit_total[5m]) + rate(postgresql_blks_read_total[5m]))", "legendFormat": "Cache Hit %", "refId": "A"}]},
    {"type": "row", "title": "Connections & Database Size", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}, "collapsed": false},
    {"type": "timeseries", "title": "Active Backends Over Time", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Max Connections"}, "properties": [{"id": "custom.lineStyle", "value": {"dash": [5, 5], "fill": "dash"}}, {"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "postgresql_backends", "legendFormat": "Active Backends", "refId": "A"}, {"expr": "postgresql_connection_max", "legendFormat": "Max Connections", "refId": "B"}]},
    {"type": "timeseries", "title": "Database Size", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "postgresql_db_size_bytes", "legendFormat": "{{postgresql_database_name}}", "refId": "A"}]},
    {"type": "row", "title": "Transactions", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}, "collapsed": false},
    {"type": "timeseries", "title": "Commits & Rollbacks", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 15}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Rollbacks"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Commits"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_commits_total[1m])", "legendFormat": "Commits", "refId": "A"}, {"expr": "rate(postgresql_rollbacks_total[1m])", "legendFormat": "Rollbacks", "refId": "B"}]},
    {"type": "timeseries", "title": "Deadlocks", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 15}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Deadlocks"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_deadlocks_total[1m])", "legendFormat": "Deadlocks", "refId": "A"}]},
    {"type": "row", "title": "Tuple Operations", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 23}, "collapsed": false},
    {"type": "timeseries", "title": "Tuple Reads (Fetched & Returned)", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_tup_fetched_total[1m])", "legendFormat": "Fetched", "refId": "A"}, {"expr": "rate(postgresql_tup_returned_total[1m])", "legendFormat": "Returned", "refId": "B"}]},
    {"type": "timeseries", "title": "Tuple Writes (Insert / Update / Delete)", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Deleted"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Inserted"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Updated"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_tup_inserted_total[1m])", "legendFormat": "Inserted", "refId": "A"}, {"expr": "rate(postgresql_tup_updated_total[1m])", "legendFormat": "Updated", "refId": "B"}, {"expr": "rate(postgresql_tup_deleted_total[1m])", "legendFormat": "Deleted", "refId": "C"}]},
    {"type": "timeseries", "title": "Live & Dead Rows", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Dead"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "sum by (state) (postgresql_rows)", "legendFormat": "{{state}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Operations by Type", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_operations_total[1m])", "legendFormat": "{{operation}}", "refId": "A"}]},
    {"type": "row", "title": "Cache & Block I/O", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 40}, "collapsed": false},
    {"type": "timeseries", "title": "Block Cache Hits vs Disk Reads", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 41}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Disk Reads"}, "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]}, {"matcher": {"id": "byName", "options": "Cache Hits"}, "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_blks_hit_total[1m])", "legendFormat": "Cache Hits", "refId": "A"}, {"expr": "rate(postgresql_blks_read_total[1m])", "legendFormat": "Disk Reads", "refId": "B"}]},
    {"type": "timeseries", "title": "Cache Hit Rate %", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 41}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "percent", "min": 0, "max": 100, "custom": {"lineWidth": 2, "fillOpacity": 15}, "thresholds": {"steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 90}, {"color": "green", "value": 98}]}}}, "options": {"tooltip": {"mode": "single"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "100 * rate(postgresql_blks_hit_total[5m]) / (rate(postgresql_blks_hit_total[5m]) + rate(postgresql_blks_read_total[5m]))", "legendFormat": "Cache Hit Rate %", "refId": "A"}]},
    {"type": "timeseries", "title": "Blocks Read (by Source & Database)", "gridPos": {"h": 8, "w": 24, "x": 0, "y": 49}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_blocks_read_total[1m])", "legendFormat": "{{source}} / {{postgresql_database_name}}", "refId": "A"}]},
    {"type": "row", "title": "BGWriter", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 57}, "collapsed": false},
    {"type": "timeseries", "title": "BGWriter Buffer Writes", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 58}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_bgwriter_buffers_writes_total[1m])", "legendFormat": "{{type}}", "refId": "A"}, {"expr": "rate(postgresql_bgwriter_buffers_allocated_total[1m])", "legendFormat": "Allocated", "refId": "B"}]},
    {"type": "timeseries", "title": "BGWriter Checkpoints & Max Written", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 58}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": [{"matcher": {"id": "byName", "options": "Max Written Stops"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}]}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_bgwriter_checkpoint_count_total[5m])", "legendFormat": "{{type}} Checkpoints", "refId": "A"}, {"expr": "rate(postgresql_bgwriter_maxwritten_total[5m])", "legendFormat": "Max Written Stops", "refId": "B"}]},
    {"type": "timeseries", "title": "BGWriter Checkpoint Duration", "gridPos": {"h": 8, "w": 24, "x": 0, "y": 66}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ms", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_bgwriter_duration_milliseconds_total[1m])", "legendFormat": "{{type}} Duration", "refId": "A"}]},
    {"type": "row", "title": "Tables & Indexes", "gridPos": {"h": 1, "w": 24, "x": 0, "y": 74}, "collapsed": false},
    {"type": "timeseries", "title": "Table Sizes (Top 10)", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 75}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "topk(10, postgresql_table_size_bytes)", "legendFormat": "{{postgresql_table_name}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Index Sizes (Top 10)", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 75}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "bytes", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "topk(10, postgresql_index_size_bytes)", "legendFormat": "{{postgresql_index_name}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Index Scans", "gridPos": {"h": 8, "w": 12, "x": 0, "y": 83}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "ops", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_index_scans_total[1m])", "legendFormat": "{{postgresql_table_name}} / {{postgresql_index_name}}", "refId": "A"}]},
    {"type": "timeseries", "title": "Table Vacuums", "gridPos": {"h": 8, "w": 12, "x": 12, "y": 83}, "datasource": {"uid": "webstore-metrics", "type": "prometheus"}, "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 10}}}, "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}}, "targets": [{"expr": "rate(postgresql_table_vacuum_count_total[5m])", "legendFormat": "{{postgresql_table_name}}", "refId": "A"}]}
  ]
}